<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="flextime_calculator.FirstTimeSetupPage"
             BackgroundColor="{StaticResource mainBackgroundColor}">

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="HorizontalOptions" Value="FillAndExpand"/>
            <Setter Property="HeightRequest" Value="55"/>
            <Setter Property="FontSize" Value="Title"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" BackgroundColor="{StaticResource settingsBackgroundColor}"/>


        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="40*"/>
                <RowDefinition Height="30*"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Text="Willkommen! 👋🏼" FontSize="Title"/>
            <Label Grid.Row="1" VerticalOptions="End" Text="Geben Sie Ihre" FontSize="Title"/>

            <!-- come Grid -->
            <Grid Grid.Row="2" x:Name="comeGrid" IsEnabled="True" IsVisible="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="60*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalOptions="Start" Text="Standard Kommen Zeit an:" FontSize="Title" LineBreakMode="WordWrap"/>
                <Border Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                    <TimePicker x:Name="setupComeTime" FontSize="Title" Time="06:00"/>
                </Border>
            </Grid>

            <!-- go Grid -->
            <Grid Grid.Row="2" x:Name="goGrid" IsEnabled="False" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="60*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalOptions="Start" Text="Standard Gehen Zeit an:" FontSize="Title" LineBreakMode="WordWrap"/>
                <Border Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                    <TimePicker x:Name="setupGoTime" FontSize="Title" Time="14:15"/>
                </Border>
            </Grid>

            <!-- weekly Grid -->
            <Grid Grid.Row="2" x:Name="weeklyGrid" IsEnabled="False" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="60*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalOptions="Start" Text="wöchentl. Stundenzahl an:" FontSize="Title" LineBreakMode="WordWrap"/>
                <HorizontalStackLayout Grid.Row="1">
                    <Entry x:Name="setupWeeklyHours" Text="37" FontSize="Title" Focused="Entry_Focused"/>
                    <Label Text="h " FontSize="Title"/>
                    <Entry x:Name="setupWeeklyMinutes" Text="30" FontSize="Title" Focused="Entry_Focused"/>
                    <Label Text="min" FontSize="Title"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- small break Grid -->
            <Grid Grid.Row="2" x:Name="smallBreakGrid" IsEnabled="False" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="35*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalOptions="Start" Text="kleine Pause an:" FontSize="Title"/>
                <HorizontalStackLayout Grid.Row="1">
                    <Label Text="Beginn: " FontSize="Large"/>
                    <Border HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                        <TimePicker x:Name="setupSmallBreakStart" FontSize="Title" Time="09:00"/>
                    </Border>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="2">
                    <Label Text="   Ende:  " FontSize="Large"/>
                    <Border HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                        <TimePicker x:Name="setupSmallBreakEnd" FontSize="Title" Time="09:15"/>
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- main break Grid -->
            <Grid Grid.Row="2" x:Name="mainBreakGrid" IsEnabled="False" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="35*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalOptions="Start" Text="Mittagspause an:" FontSize="Title"/>
                <HorizontalStackLayout Grid.Row="1">
                    <Label Text="Beginn: " FontSize="Large"/>
                    <Border HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                        <TimePicker x:Name="setupMainBreakStart" FontSize="Title" Time="12:00"/>
                    </Border>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="2">
                    <Label Text="   Ende:  " FontSize="Large"/>
                    <Border HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="90">
                        <TimePicker x:Name="setupMainBreakEnd" FontSize="Title" Time="12:30"/>
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- Menu buttons -->
            <HorizontalStackLayout Grid.Row="3">
                <Button x:Name="BackButton" BackgroundColor="{StaticResource backButtonBackgroundColor}" IsEnabled="False" Opacity="0.5"
                        Text="Zurück" TextColor="White" Clicked="BackButton_Clicked"/>
                <Button x:Name="NextButton" Text="Nächste" TextColor="White" Clicked="NextButton_Clicked"/>
            </HorizontalStackLayout>

        </Grid>

    </Grid>
    
</ContentPage>