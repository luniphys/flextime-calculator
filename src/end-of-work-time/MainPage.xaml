<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="end_of_work_time.MainPage">
    <ContentPage.Resources>

        <Style TargetType="Label">
            <Setter Property="VerticalTextAlignment" Value="Center"/>
            <Setter Property="HorizontalTextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>

        <Style TargetType="Entry">
            <Setter Property="Text" Value="Time"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="10,10,10,10"/>
        </Style>

    </ContentPage.Resources>

    <Grid Background="#FF1e1e1e">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="40*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Menu -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="90*"/>
            </Grid.RowDefinitions>

            <Button Text="Menu"/>

        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <Label Text="Monday"/>
            <Label Grid.Row="1" Text="Tuesday"/>
            <Label Grid.Row="2" Text="Wednesday"/>
            <Label Grid.Row="3" Text="Thursday"/>
            <Label Grid.Row="4" Text="Friday"/>
            
        </Grid>

        <!-- Come time -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <Entry/>
            <Entry Grid.Row="1"/>
            <Entry Grid.Row="2"/>
            <Entry Grid.Row="3"/>
            <Entry Grid.Row="4"/>
            
        </Grid>

        <!-- Go time -->
        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <Entry/>
            <Entry Grid.Row="1"/>
            <Entry Grid.Row="2"/>
            <Entry Grid.Row="3"/>
            <Entry Grid.Row="4"/>
            
        </Grid>

    </Grid>
    
</ContentPage>
