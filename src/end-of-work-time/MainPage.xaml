<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="end_of_work_time.MainPage">
    <ContentPage.Resources>

        <Style TargetType="HorizontalStackLayout">
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>
        
    </ContentPage.Resources>

    <Grid Background="#FF1e1e1e">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="95*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Menu -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="90*"/>
            </Grid.RowDefinitions>

            <Button Text="Menu"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*"/>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="40*"/>
                </Grid.ColumnDefinitions>
            
                <!-- Days -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                    </Grid.RowDefinitions>

                    <Label Text="Monday"/>
                    <Label Grid.Row="1" Text="Tuesday"/>
                    <Label Grid.Row="2" Text="Wednesday"/>
                    <Label Grid.Row="3" Text="Thursday"/>
                    <Label Grid.Row="4" Text="Friday"/>
                </Grid>

                <!-- Come times -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                    </Grid.RowDefinitions>

                    <HorizontalStackLayout>
                        <Label Text="Come:"/>
                        <Entry Text="06:00" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1">
                        <Label Text="Come:"/>
                        <Entry Text="06:00" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="2">
                        <Label Text="Come:"/>
                        <Entry Text="06:00" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="3">
                        <Label Text="Come:"/>
                        <Entry Text="06:00" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="4">
                        <Label Text="Come:"/>
                        <Entry Text="06:00" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Go times -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="20*"/>
                    </Grid.RowDefinitions>

                    <HorizontalStackLayout Grid.Row="0">
                        <Label Text="Go:"/>
                        <Entry Text="14:15" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1">
                        <Label Text="Go:"/>
                        <Entry Text="14:15" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="2">
                        <Label Text="Go:"/>
                        <Entry Text="14:15" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="3">
                        <Label Text="Go:"/>
                        <Entry Text="14:15" Focused="OnEntryFocused" TextChanged="OnEntryTextChanged"/>
                    </HorizontalStackLayout>
                </Grid>

            </Grid>

            <!-- Resulting end of work time -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition  Width="49*"/>
                    <ColumnDefinition  Width="2*"/>
                    <ColumnDefinition  Width="49*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Text="Feierabend:" HorizontalTextAlignment="End"/>
                <Label Grid.Column="1"/>
                <Label Grid.Column="2" Text="Time" HorizontalTextAlignment="Start"/>
            </Grid>

        </Grid>

    </Grid>
    
</ContentPage>
